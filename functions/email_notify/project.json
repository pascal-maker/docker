{
  "name": "fn-email-notify",
  "root": "functions/email_notify",
  "projectType": "application",
  "tags": ["scope:functions", "type:app", "lang:python"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.py",
        "{workspaceRoot}/pyproject.toml"
      ],
      "options": {
        "command": "uv run --package refactor-agent ruff check functions/email_notify/",
        "cwd": "{workspaceRoot}"
      }
    },
    "bundle": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv export --frozen --no-dev --no-editable --package email-notify -o functions/email_notify/requirements.txt",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
