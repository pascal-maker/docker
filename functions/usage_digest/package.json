{
  "name": "usage-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "lint": "oxlint --type-aware src",
    "typecheck": "tsc --noEmit",
    "start": "functions-framework --target=usageDigest"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.0.0",
    "@google-cloud/functions-framework": "^5.0.0",
    "@google-cloud/monitoring": "^5.3.1",
    "@refactor-agent/functions-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "oxlint": "^1.0.0",
    "prettier": "^3.3.3",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
