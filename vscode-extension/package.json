{
  "name": "refactor-agent",
  "displayName": "Refactor Agent",
  "description": "Refactor Agent – rename symbols via A2A (Python or TypeScript). Standalone sidebar panel.",
  "version": "0.1.0",
  "publisher": "refactor-agent",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "activationEvents": [
    "onView:refactorAgent-refactorView",
    "onCommand:refactorAgent.focusView",
    "onCommand:refactorAgent.openWebviewDevTools"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "refactorAgent-sidebar",
          "title": "Refactor Agent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "refactorAgent-sidebar": [
        {
          "type": "webview",
          "id": "refactorAgent-refactorView",
          "name": "Refactor",
          "contextTitle": "Refactor Agent"
        }
      ]
    },
    "commands": [
      {
        "command": "refactorAgent.focusView",
        "title": "Refactor Agent: Focus Refactor View"
      },
      {
        "command": "refactorAgent.openWebviewDevTools",
        "title": "Refactor Agent: Open Webview Developer Tools"
      }
    ],
    "configuration": {
      "title": "Refactor Agent",
      "properties": {
        "refactorAgent.a2aBaseUrl": {
          "type": "string",
          "default": "http://localhost:9999",
          "description": "A2A server base URL (e.g. http://localhost:9999 or https://refactor-agent.example.com)"
        },
        "refactorAgent.syncUrl": {
          "type": "string",
          "default": "",
          "description": "Sync service URL. When empty, uses A2A base URL (same for hosted Cloud Run)."
        },
        "refactorAgent.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional API key for hosted A2A (sent as Authorization: Bearer <key>)",
          "secret": true
        },
        "refactorAgent.engine": {
          "type": "string",
          "default": "python",
          "enum": ["python", "typescript"],
          "description": "Language engine (must match opened workspace; set by try_extension.sh <playground>)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "format": "prettier --write \"src/**/*.ts\"",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.15.0"
  }
}
