{
  "name": "ts-morph-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "JSON-RPC bridge exposing ts-morph operations over stdin/stdout",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/node": "^8.55.0",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.15.0"
  }
}
