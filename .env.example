# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Chainlit persistence and auth (required for chat history and sharing)
# Postgres is provided by Docker: docker compose up postgres (or postgres chainlit).
POSTGRES_USER=chainlit
POSTGRES_PASSWORD=chainlit
POSTGRES_DB=chainlit
# When running "make ui" on host, point at localhost. When Chainlit runs in Docker,
# it uses DATABASE_URL from compose. Use postgresql:// (Chainlit uses asyncpg; do not use postgresql+asyncpg).
DATABASE_URL=postgresql://chainlit:chainlit@localhost:5432/chainlit
# Generate secret: chainlit create-secret
CHAINLIT_AUTH_SECRET=
# Environment label for this instance (dev, staging, prod). One instance per env.
CHAINLIT_ENVIRONMENT=dev

# LLM API keys (add whichever you use)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# VS Code extension + sync (try_extension.sh, run_refactor_backend)
GOOGLE_CLOUD_PROJECT=refactor-agent

# Refactor issues dashboard (optional)
# REFACTOR_AGENT_DASHBOARD_DB=dashboard.db
# REFACTOR_AGENT_DASHBOARD_PORT=8000
# REFACTOR_AGENT_INGEST_API_KEY=your-secret-key-for-ci-ingestion
