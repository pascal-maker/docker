# Copy to secrets.tfvars and set real values. Do not commit secrets.tfvars.
# Then: terraform apply -var-file=dev.tfvars -var-file=secrets.tfvars
# To change a key or add a provider: edit this (or secrets.tfvars), add variable in variables.tf
# and secret_version in secrets.tf if new, then apply.
#
# Sentry: sentry_auth_token + sentry_organization. For EU region add:
#   sentry_base_url = "https://de.sentry.io/api/"
#
# Cloudflare (optional): cloudflare_api_token + cloudflare_email_destination.
# Add domain in Resend and Firebase first, then set resend_dkim_* and firebase_hosting_*.

anthropic_api_key     = ""
chainlit_auth_secret  = ""
sentry_auth_token     = ""
sentry_organization   = ""
# sentry_base_url    = "https://de.sentry.io/api/"  # uncomment for EU

# cloudflare_api_token      = ""
# cloudflare_email_destination = ""
# resend_dkim_name          = "resend._domainkey"
# resend_dkim_target        = "..."  # from Resend Dashboard
# firebase_hosting_target   = "..."  # from Firebase Console
# firebase_hosting_type     = "CNAME"
# firebase_hosting_name     = "www"
#
# GitHub Actions secrets (optional): github_token + github_repository.
# github_token      = ""  # admin:repo scope
# github_repository = "owner/refactor-agent"
# github_oauth_client_id    = ""  # for site build + GitHub secrets sync
# github_oauth_client_secret = ""  # required for auth callback; from GitHub OAuth App
# firebase_service_account_json = ""  # JSON key for Firebase Hosting deploy; Terraform syncs to FIREBASE_SERVICE_ACCOUNT
# resend_api_key           = ""  # required for email notify; from Resend Dashboard
#
# GDPR / legal (Belgium). Terraform syncs to GitHub Actions variables for site build.
# vite_imprint_name        = ""  # e.g. "Thomas Decloedt"
# vite_imprint_email       = ""  # e.g. "thomas@refactorum.com"
# vite_privacy_policy_url  = ""  # hosted URL (Termly/iubenda) or leave empty for /privacy
# vite_terms_url           = ""  # hosted URL or leave empty for /terms
# vite_firebase_measurement_id = ""  # optional override; Terraform auto-creates web app and gets Measurement ID
