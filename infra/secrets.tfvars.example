# Copy to secrets.tfvars and set real values. Do not commit secrets.tfvars.
# Then: terraform apply -var-file=dev.tfvars -var-file=secrets.tfvars
# To change a key or add a provider: edit this (or secrets.tfvars), add variable in variables.tf
# and secret_version in secrets.tf if new, then apply.
#
# Sentry: sentry_auth_token + sentry_organization. For EU region add:
#   sentry_base_url = "https://de.sentry.io/api/"

anthropic_api_key    = ""
chainlit_auth_secret = ""
sentry_auth_token    = ""
sentry_organization  = ""
# sentry_base_url   = "https://de.sentry.io/api/"  # uncomment for EU
