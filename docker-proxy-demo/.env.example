# Application Configuration Example
# Copy this file to .env and customize as needed

# Proxy external port
PROXY_PORT=8080
PYTHON_VERSION=3.14

# Web App Instances Configuration
WEBAPP1_NAME=WebApp-1
WEBAPP1_COLOR=#FF6B6B

WEBAPP2_NAME=WebApp-2
WEBAPP2_COLOR=#4ECDC4

WEBAPP3_NAME=WebApp-3
WEBAPP3_COLOR=#45B7D1

# Network Configuration
FRONTEND_NETWORK=frontend
BACKEND_NETWORK=backend
PROXY_LOGS_VOLUME=proxy_logs
EXTERNAL_WEB_HOST_PORT=5050

# Restart Policy (unless-stopped, always, on-failure, no)
RESTART_POLICY=unless-stopped
