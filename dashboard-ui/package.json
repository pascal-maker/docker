    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "oxlint": "^1.0.0",
    "oxlint-tsgolint": "^0.15.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
