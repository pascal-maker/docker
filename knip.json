{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/dashboard": {
      "entry": [
        "src/main.tsx"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "apps/site": {
      "entry": [
        "src/main.tsx"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "packages/design-system": {
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "packages/ts-morph-bridge": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "apps/vscode-extension": {
      "project": [
        "src/**/*.ts"
      ]
    }
  },
  "ignore": [
    "playground/**"
  ],
  "ignoreDependencies": [
    "@types/react-dom",
    "react-dom"
  ],
  "ignoreBinaries": [
    "uv"
  ]
}