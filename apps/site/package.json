{
  "name": "site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node_modules/.bin/vite",
    "build": "node_modules/.bin/tsc -b && node scripts/write-auth-config.js && vite build",
    "preview": "node_modules/.bin/vite preview",
    "format": "node_modules/.bin/prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format-check": "node_modules/.bin/prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint": "node_modules/.bin/oxlint --type-aware",
    "typecheck": "node_modules/.bin/tsc --noEmit"
  },
  "dependencies": {
    "@refactor-agent/design-system": "workspace:*",
    "@sentry/react": "^10.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "oxlint": "^1.0.0",
    "oxlint-tsgolint": "^0.15.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
