# Build-time env (from Terraform/GitHub Actions in CI, or set locally for dev)
VITE_GITHUB_OAUTH_CLIENT_ID=
VITE_AUTH_CALLBACK_URL=

# Sentry DSN. Get: terraform -chdir=infra output -raw sentry_dsn_frontend
VITE_SENTRY_DSN=

# Hosted legal pages (Termly/iubenda). Create policies, get URLs, paste here.
VITE_PRIVACY_POLICY_URL=
VITE_TERMS_URL=

# Imprint / Legal notice (Belgium). Required: name, email. Optional: address, CBE, VAT.
VITE_IMPRINT_NAME=
VITE_IMPRINT_EMAIL=
# VITE_IMPRINT_ADDRESS=
# VITE_IMPRINT_CBE=
# VITE_IMPRINT_VAT=

# Firebase Analytics (consent-gated). Get from Firebase Console → Project Settings → Your apps.
VITE_FIREBASE_MEASUREMENT_ID=
